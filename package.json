{
  "name": "bdsa-nft-reviewer",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Standalone reviewer app for BDSA NFT (neurofibrillary tangle) detections on Alzheimer's brain slides. Wraps bdsa-react-components in an intuitive single-screen workflow.",
  "scripts": {
    "setup": "node scripts/setup.mjs",
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "bdsa-react-components": "file:../bdsa-react-components",
    "openseadragon": "^5.0.1",
    "paper": "^0.12.18",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.22.0"
  },
  "devDependencies": {
    "@types/openseadragon": "^5.0.2",
    "@types/react": "^18.2.43",
    "@types/react-dom": "^18.2.17",
    "@vitejs/plugin-react": "^4.2.1",
    "typescript": "^5.3.3",
    "vite": "^5.0.10"
  }
}
